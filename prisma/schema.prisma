generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

model Corrida {
    id                 String   @id @default(auto()) @map("_id") @db.ObjectId
    stravaId           Int      @unique
    nome               String
    tipoEsporte        String
    distanciaMetros    Float
    tempoMovimentoSeg  Int
    tempoTotalSeg      Int
    elevacaoGanhoMetros Float
    dataInicio         DateTime
    velocidadeMedia    Float?
    velocidadeMaxima   Float?
    frequenciaMedia    Float?
    frequenciaMaxima   Float?
    dadosBrutos        Json
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt

    @@index([dataInicio])
    @@index([tipoEsporte])
}
