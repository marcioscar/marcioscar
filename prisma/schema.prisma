generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

model Corrida {
    id                  String   @id @default(auto()) @map("_id") @db.ObjectId
    stravaId            Int      @unique
    nome                String
    tipoEsporte         String
    distanciaMetros     Float
    tempoMovimentoSeg   Int
    tempoTotalSeg       Int
    elevacaoGanhoMetros Float
    dataInicio          DateTime
    velocidadeMedia     Float?
    velocidadeMaxima    Float?
    frequenciaMedia     Float?
    frequenciaMaxima    Float?
    dadosBrutos         Json
    analise             Json?
    analisadaEm         DateTime?
    createdAt           DateTime @default(now())
    updatedAt           DateTime @updatedAt

    @@index([dataInicio])
    @@index([tipoEsporte])
}

model despesas {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    nome        String
    categoria   String
    valor       Float
    data        DateTime
    brassaco    Boolean
    comprovante String
    conta       String
    fatura      String? // permite nulo
    obs         String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([data])
    @@index([categoria])
}

model pagamentosBrassaco {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    valor     Float
    data      DateTime
    obs       String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([data])
}

model ProvaAlvo {
    id               String   @id @default(auto()) @map("_id") @db.ObjectId
    nome             String
    plano            String
    dataProva        DateTime
    paceAlvo         String
    kmSemanais       Int
    diasTreino       String[]
    semanasCompletas Int[]
    ativa            Boolean  @default(false)
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    @@index([dataProva])
}

model biblioteca {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    nome      String
    data      DateTime
    capa      String
    citacao   String
    nota      String
    autor     String
    /// Páginas do livro (opcional); usado nas estatísticas de leitura
    paginas   Int?
    // Opcionais: documentos antigos/importados podem vir sem timestamps no MongoDB
    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt

    @@index([data])
}
